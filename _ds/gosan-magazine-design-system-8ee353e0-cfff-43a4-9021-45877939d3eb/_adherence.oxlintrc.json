{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/editorial/**",
              "components/forms/**",
              "components/motifs/**",
              "components/quotes/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lateef|Vazirmatn|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Lateef, Vazirmatn, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|tagVariant|title|excerpt|date|author|href|key|ref|className|style|children)$/]",
        "message": "<ArticleCard> doesn't accept that prop. Declared props: tag, tagVariant, title, excerpt, date, author, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute[name.name='tagVariant'] > Literal[value!=/^(?:cerulean|gold)$/]",
        "message": "<ArticleCard> tagVariant must be one of 'cerulean' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DraftFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|style|key|ref|className|style|children)$/]",
        "message": "<DraftFrame> doesn't accept that prop. Declared props: children, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|multiline|placeholder|id|value|onChange|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, type, multiline, placeholder, id, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email)$/]",
        "message": "<FormField> type must be one of 'text' | 'email'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GoldDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|style|key|ref|className|style|children)$/]",
        "message": "<GoldDots> doesn't accept that prop. Declared props: width, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|cite|style|key|ref|className|style|children)$/]",
        "message": "<PullQuote> doesn't accept that prop. Declared props: children, cite, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHead'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|moreLabel|moreHref|children|key|ref|className|style|children)$/]",
        "message": "<SectionHead> doesn't accept that prop. Declared props: title, moreLabel, moreHref, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:cerulean|gold)$/]",
        "message": "<Tag> variant must be one of 'cerulean' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Verse'] > JSXAttribute > JSXIdentifier[name!=/^(?:hemistichs|poet|key|ref|className|style|children)$/]",
        "message": "<Verse> doesn't accept that prop. Declared props: hemistichs, poet."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
